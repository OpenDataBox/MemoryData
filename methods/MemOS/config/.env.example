# MemOS environment variables
# Copy this file to .env in the project root and fill in your values

# Required: OpenAI API key (or compatible endpoint key)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: API base URL (for OpenAI-compatible endpoints like local vLLM, etc.)
OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Text memory type ("general_text" or "tree_text")
MOS_TEXT_MEM_TYPE=general_text

# Optional: MemOS data directory (defaults to .memos in current working directory)
# MEMOS_BASE_PATH=/path/to/your/data
